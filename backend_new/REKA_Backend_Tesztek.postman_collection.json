{
  "info": {
    "name": "RÉKA – Backend Tesztek",
    "description": "RÉKA vállalatirányítási rendszer backend API tesztjei (18 végpont). A tesztek sorban futtatva önállóan működnek: az első kérés (Bejelentkezés) automatikusan elmenti a JWT tokent, amelyet az összes többi kérés felhasznál.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "BASE_URL",
      "value": "http://localhost:3000",
      "type": "string",
      "description": "A backend szerver alap URL-je. Módosítsd szükség esetén."
    },
    {
      "key": "JWT_TOKEN",
      "value": "",
      "type": "string",
      "description": "A bejelentkezés után automatikusan töltődik fel."
    }
  ],
  "item": [
    {
      "name": "6.1 – Bejelentkezés",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": { "raw": "{{BASE_URL}}/api/Bejelent", "host": ["{{BASE_URL}}"], "path": ["api", "Bejelent"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"Adminisztrátor Anna\",\n  \"password\": \"pass_1\"\n}"
        },
        "description": "Sikeres bejelentkezés érvényes felhasználói adatokkal. JWT tokent ad vissza, amelyet a teszt automatikusan elment a JWT_TOKEN változóba."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"HTTP státusz 200\", () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test(\"ok mező: true\", () => pm.expect(json.ok).to.be.true);",
              "pm.test(\"token mező létezik\", () => pm.expect(json.token).to.be.a('string').and.not.empty);",
              "pm.test(\"felhasznalo objektum létezik\", () => pm.expect(json.felhasznalo).to.be.an('object'));",
              "pm.test(\"ceg objektum létezik\", () => pm.expect(json.ceg).to.exist);",
              "if (json.token) { pm.collectionVariables.set('JWT_TOKEN', json.token); }"
            ]
          }
        }
      ]
    },
