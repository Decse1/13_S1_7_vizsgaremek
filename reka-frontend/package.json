{
  "name": "reka-frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "pretest": "npx geckodriver --version",
    "test": "mocha --require tests/e2e/setup.js tests/e2e/**/*.test.js",
    "test:login": "mocha --require tests/e2e/setup.js tests/e2e/login.test.js",
    "test:register": "mocha --require tests/e2e/setup.js tests/e2e/register.test.js",
    "test:sbmenus": "mocha --require tests/e2e/setup.js tests/e2e/sbmenus.test.js",
    "test:watch": "mocha --require tests/e2e/setup.js tests/e2e/**/*.test.js --watch",
    "test:grep": "mocha --require tests/e2e/setup.js tests/e2e/**/*.test.js --grep"
  },
  "dependencies": {
    "@heroicons/vue": "^2.2.0",
    "axios": "^1.13.2",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "bootstrap-vue-next": "^0.40.8",
    "router": "^2.2.0",
    "vue": "^3.5.22",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "geckodriver": "^6.1.0",
    "mocha": "^11.7.5",
    "selenium-webdriver": "^4.41.0",
    "vite": "^7.1.11",
    "vite-plugin-vue-devtools": "^8.0.3"
  }
